{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the finance system with a specific role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["viewer", "analyst", "admin"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "FinancialRecord": {
      "title": "Financial Record",
      "description": "An income or expense entry.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "createdBy": { "type": "string", "description": "UID of the user who created the record" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "type", "category", "date", "createdBy"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile and role information."
    },
    "/records/{recordId}": {
      "schema": "FinancialRecord",
      "description": "Financial transactions."
    }
  }
}
