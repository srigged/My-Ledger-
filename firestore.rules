rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (optional)
    //   - role: string (required, enum: viewer, analyst, admin)
    //   - status: string (required, enum: active, inactive)
    //   - createdAt: timestamp (required)
    //
    // Collection: records
    // Document ID: {recordId}
    // Fields:
    //   - amount: number (required, positive)
    //   - type: string (required, enum: income, expense)
    //   - category: string (required)
    //   - date: timestamp (required)
    //   - description: string (optional)
    //   - createdBy: string (required, UID)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || (request.auth.token.email == "pandeygs14@gmail.com" && request.auth.token.email_verified == true);
    }

    function isAnalyst() {
      return hasRole('analyst') || isAdmin();
    }

    function isViewer() {
      return hasRole('viewer') || isAnalyst();
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'viewer'; // Default role
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // Financial Record Rules
    match /records/{recordId} {
      allow read: if isViewer();
      allow create: if isAdmin() || isAnalyst();
      allow update: if isAdmin() || (isAnalyst() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
